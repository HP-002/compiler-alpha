(* Invalid Tests for expressions *)

type Point : [integer : x; integer : y; Boolean : b; character : c]
type IntArray: 1 -> integer
type int2int: integer -> integer

function func1 : int2int
function func2 : int2int

type void : integer -> integer
function entry : void

entry(x) := {
    [integer : i1; integer : i2;
     character : c1; character : c2;
     Boolean : b1; Boolean : b2;
     Point : p1; Point : p2;
     IntArray: arr1; IntArray: arr2 ]

    (* Boolean Expressions *)
    b1 := 1;
    b1 := 'a';
    b1 := null;
    b1 := p1;
    b1 := i1 + i2;
    b1 := true + false;
    b1 := b1 - 1;
    b1 := true * 10;

    b1 := true < 10;
    b1 := 'a' = false;
    b1 := b1 = i1;
    b1 := !i1;
    b1 := !c1;
    b1 := !null;
    b1 := !(i1 + i2);

    b1 := b1 | 10;
    b1 := 'a' | false;
    b1 := null | null;
    b1 := (i1 < i2) | i1;
    b1 := b1 & c1;
    b1 := 0 & 1;
    b1 := true & p1;

    (* Integer Expressions *)
    i1 := true;
    i1 := 'x';
    i1 := null;
    i1 := p1;
    i1 := arr1;

    i1 := i1 < i2;
    i1 := i1 = 10;
    i1 := (i1 + 5) < 20;

    i1 := i1 + true;
    i1 := 'a' - i2;
    i1 := i1 * null;
    i1 := p1 / 10;
    i1 := b1 % i2;
    i1 := -true;
    i1 := -'c';
    i1 := -null;
    i1 := -p1;

    i1 := i1 + (i1 < i2);
    i1 := (i1 & i2) + 10;
    i1 := !i1 + 5;
    i1 := i1 + i2 * ((i2 + c1) * (i1 * i1));

    (* Less Than (<) Expressions *)
    b1 := i1 < c1;
    b1 := true < 10;
    b1 := 'a' < false;
    b1 := i1 < null;
    b1 := (i1 + 5) < 'z';
    b1 := (i1 < i2) < i1;
    b1 := i1 < (i2 < 10);
    
    b1 := p1 < p2;
    b1 := arr1 < arr2;
    b1 := func1 < func2;
    b1 := null < null;

    i1 := i1 < i2;
    c1 := 'a' < 'b';
    p1 := 10 < 20;


    (* Equal To (=) Expressions *)
    b1 := i1 = true;
    b1 := c1 = 10;
    b1 := false = 'f';
    b1 := (i1 + i2) = c1;
    b1 := p1 = i1;
    b1 := arr1 = false;
    b1 := c1 = func2;


    b1 := i1 = null;
    b1 := null = c1;
    b1 := true = null;
    b1 := p1 = arr1;
    b1 := arr2 = func1;
    b1 := func1 = p2;

    i1 := i1 = i2;
    p1 := c1 = c2;
    arr1 := null = null;

    b1 := (i1 = i2) = i1;
    b1 := p1 = (p1 = null);

    (* Release/Reserve Expressions *)
    i1 := reserve i1;
    b1 := release b2;
    c1 := reserve c1;
    func1 := reserve func1;
    func2 := release func2;

    arr1 := reserve arr1;
    arr1 := reserve arr1(10, 20);
    arr1 := reserve arr1(true);
    arr1 := reserve arr1('a');
    arr1 := reserve arr1(null);

    p1 := reserve p1(10);

    arr1 := release arr1(10);
    p1 := release p1(5);

    i1 := reserve p1;
    arr1 := p1;
    b1 := reserve arr2(10);
}
