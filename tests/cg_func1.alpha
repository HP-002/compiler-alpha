type integer2integer : integer -> integer
type character2integer : character -> integer
external function printInteger : integer2integer
external function printCharacter : character2integer
function factorial : integer2integer
factorial(n) := {
    [integer : next; integer : result]
    if (n = 0) then {
        return 1;
    } else {
        next := n - 1;
        result := factorial(next);
        return n * result;
    }
}

function entry : integer2integer
entry(arg) := {
    [integer : i; integer : t]
    i := factorial(5);    
    t := printInteger(i);
    t := printCharacter('\n');
    return 0;
}