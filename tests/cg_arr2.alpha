type iarr2 : 2 -> integer
type string2integer : string -> integer
function entry : string2integer
entry(arg) := {
    [iarr2 : mat; integer : i; integer : j; integer : sum]
    
    mat := reserve mat(2, 2);
    
    mat(0, 0) := 10;
    mat(0, 1) := 20;
    mat(1, 0) := 30;
    mat(1, 1) := 40;

    i := 1;
    j := 0;
    mat(i, j) := mat(i, j) + 5;
    
    sum := mat(0, 0) + mat(0, 1) + mat(1, 0) + mat(1, 1);
    return sum;
}