type string2integer : string -> integer
function entry : string2integer
entry(arg) := {
    [integer : a; integer : b; integer : c]
    a := 10;
    b := 12;
    c := 10 * 22;
    c := a * 2;
    c := a * b;
    c := 10 / 2;
    c := 100 / a;
    c := a / b;
    c := 20 % 3;
    c := a % 2;
    c := a % b;
    return 0;
}