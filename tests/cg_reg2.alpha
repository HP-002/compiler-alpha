type integer2integer : integer -> integer
function entry : integer2integer
entry(arg) := {
    [integer : t1; integer : t2; integer : t3; integer : t4; integer : t5; integer : t6; integer : t7; integer : t8; integer : t9; integer : t10; integer : t11; integer : t12; integer : sum]
    t1 := 1;
    t2 := 2;
    t3 := 3;
    t4 := 4;
    t5 := 5;
    t6 := 6;
    t7 := 7;
    t8 := 8;
    t9 := 9;
    t10 := 10;
    t11 := 11;
    t12 := 12;
    sum := (((t1 + t2) + (t3 + t4)) + ((t5 + t6) + (t7 + t8))) + (((t9 + t10) + (t11 + t12)));
    return 0;
}