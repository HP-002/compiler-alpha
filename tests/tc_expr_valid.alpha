(* Valid Tests for expressions *)

type Point : [integer : x; integer : y; Boolean : b; character : c]
type IntArray: 1 -> integer
type int2int: integer -> IntArray

function func1 : int2int
function func2 : int2int

type void : integer -> integer
function entry : void

entry(x) := {
    [integer : i1; integer : i2;
     character : c1; character : c2;
     Boolean : b1; Boolean : b2;
     Point : p1; Point : p2;
     IntArray: arr1; IntArray: arr2 ]

    (* Boolean Expressions *)
    b1 := true;
    b2 := false;
    b1 := b2;
    b1 := ((b2));
    b1 := b1 | b2;
    b1 := b1 & b2;
    b1 := ((b1 | b2) & (b2 & b2)) & b1 | b2;
    b1 := ((true | false | b2) & (b2 & true)) & b1 | false;

    (* Integer Expressions *)
    i1 := 10;
    i2 := 2023943081;
    i1 := -1023;
    i2 := 0;
    i1 := 0 + i1;
    i1 := -10 + i1;
    i1 := 10 + 203 - 0 - i2 + i1;
    i1 := ((i1));
    i1 := -i2;
    i1 := -(-i1);
    
    i1 := i1 + i2;
    i1 := i1 - i2;
    i1 := i1 * i2;
    i1 := i1 / i2;
    i1 := i1 % i2;
    
    i1 := i1 + 100;
    i1 := 500 - i2;
    i1 := 0 * i1;
    i1 := i1 / 1;
    i1 := i2 % 10;

    i1 := i1 + i2 * 10;
    i1 := i1 * i2 + 10;
    i1 := i1 - i2 - 10;
    i1 := i1 / i2 * 10;
    i1 := 10 + 203 - 0 - i2 + i1;
    i1 := -10 + i1 * -5;

    i1 := (i1 + i2) * 10;
    i1 := i1 * (i2 + 10);
    i1 := (i1 - i2) / (i1 + 1);
    i1 := ((i1 % 2) + (i2 * 3)) / 5;
    i1 := -((i1 + i2) * 10);
    
    (* Less Than (<) Expressions *)
    b1 := i1 < i2;
    b1 := i1 < 100;
    b1 := -10 < -5;
    b1 := (i1 + i2) < (i1 * 2);

    b1 := i1 < i2;
    b1 := i1 < 100;
    b1 := 50 < i2;
    b1 := -10 < -5;
    b1 := -10 < (-5);
    b1 := (i1 + i2) < (i1 * 2);
    b1 := (i1 % 2) < 1;
    b1 := -i1 < (i2 / 4);

    b1 := c1 < c2;
    b1 := c1 < 'z';
    b1 := 'A' < c2;
    b1 := 'a' < 'b';

    b1 := b1 < b2;
    b1 := b1 < true;
    b1 := false < b2;
    b1 := false < true;
    b1 := (b1 & b2) < (b1 | true);

    b1 := (i1 < i2) & (c1 < 'z'); 
    b1 := (b1 < true) | (i1 < 0);
    b1 := ! (i1 < i2);

    (* Equal To (=) Expressions *)
    b1 := i1 = i2;
    b1 := i1 = 100;
    b1 := -10 = -5;
    b1 := (i1 + i2) = (i1 * 2);

    b1 := i1 = i2;
    b1 := i1 = 100;
    b1 := 50 = i2;
    b1 := -10 = -5;
    b1 := -10 = (-5);
    b1 := (i1 + i2) = (i1 * 2);
    b1 := (i1 % 2) = 1;
    b1 := -i1 = (i2 / 4);

    b1 := c1 = c2;
    b1 := c1 = 'z';
    b1 := 'A' = c2;
    b1 := 'a' = 'b';

    b1 := b1 = b2;
    b1 := b1 = true;
    b1 := false = b2;
    b1 := false = true;
    b1 := (b1 & b2) = (b1 | true);

    b1 := (i1 = i2) & (c1 = 'z'); 
    b1 := (b1 = true) | (i1 = 0);
    b1 := ! (i1 = i2);

    b1 := p1 = p2;
    b1 := p1 = null;
    b1 := null = p2;
    b1 := arr1 = arr2;
    b1 := arr1 = null;
    b1 := null = arr2;

    b1 := func1(i1) = func2(i1);
    b1 := func1(i1) = null;
    b1 := null = func2(i1);
    b1 := null = null;

    (* Release/Reserve Expressions *)
    p1 := reserve p1;
    p2 := reserve p2;
    p1 := release p1;
    p2 := release p2;
    p1 := null;
    p2 := p1;
    
    arr1 := reserve arr1(10);
    arr2 := reserve arr2(i1 + 5);
    arr1 := release arr1;
    arr2 := release arr2;
    arr1 := null;
    arr2 := arr1;

    b1 := (reserve p1) = null;
    b1 := (release arr1) = null;
}
