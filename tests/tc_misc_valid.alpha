(* Valid Misc Tests *)

type Point : [integer : x; integer : y]
type Circle : [Point : center; integer : radius]
type Sphere : [Circle : base; integer : z_height]

type Grid3D : 3 -> integer

type IntOp : integer -> integer
type void : integer -> integer

function factorial : IntOp
function process_grid : IntOp
function entry : void

entry(arg) := {
    [
        Sphere : s1;
        Grid3D : space;
        integer : i1
    ]

    s1 := reserve s1;

    s1.base.center.x := 10;
    s1.base.center.y := 20;
    s1.base.radius := 5;
    s1.z_height := 100;

    space := reserve space(10, 10, 10);
    space(0, 5, 9) := s1.base.center.x * 2; 

    if ( (s1.base.center.x < s1.base.center.y) & (space(0,5,9) = 20) | !(s1.z_height < 0) ) then {
        i1 := factorial(5);
    } else {
        i1 := 0;
    }
}

factorial(n) := {
    [ integer : result ]
    
    if (n < 2) then {
        result := 1;
    } else {
        result := n * factorial(n - 1);
    }
    
    return result;
}
