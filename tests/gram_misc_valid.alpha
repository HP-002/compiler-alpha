(* miscelaneous *)
type IntArray : 1 -> integer
type Matrix : 2 -> integer
type Int2Int : integer -> integer

function process : Int2Int

process(x) := {
    (* Missing return *)
    while (x < 10) {
        x := x + 1;
    }
}

entry(arg) := {
    [ integer: a; boolean: flag; IntArray: arr; Matrix: m ]
    
    a := 5;
    flag := false;

    (* multiple unary operators *)
    flag := !!flag;
    a := - - a;

    (* memory operators inside function calls *)
    a := process(reserve IntArray(10));
    
    (* array allocation with multiple dimensions *)
    m := reserve m(5, 5);
    
    (* releasing an element returned from an array *)
    a := release arr(0);
    
    (* single-statement nested block without semicolons *)
    {
        while(flag) {
            a := a + 1;
        }
    }

    return 0;
}