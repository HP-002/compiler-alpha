(* invalid compound statements *)
entry(arg) := {
    [ integer: x; boolean: flag ]
    
    x := 10;
    flag := true;

    if (flag) then {
        x := 0;
    }

    while x < 20 {
        x := x + 1;
    }

    if (x = 10) {
        x := 5;
    } else {
        x := 0;
    }

    while (flag) {
        flag := false;
    };

    return 0;
}