type void : integer -> integer
function entry : void

entry(arg) := {
    [ integer : x; integer : evenCount; integer : oddCount ]
    
    x := 10;
    evenCount := 0;
    oddCount := 0;

    while (0 < x) {
        
        if (x % 2 = 0) then {
            evenCount := evenCount + 1;
        } else {
            oddCount := oddCount + 1;
        }
        
        x := x - 1;
    }

    return 0;
}
